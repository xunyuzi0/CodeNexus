# ==============================
# 1. 系统与 IDE 通用忽略 (不要上传你的个人配置)
# ==============================
.idea/
*.iml
.vscode/
*.DS_Store
Thumbs.db
*.log

# ==============================
# 2. 后端 Backend (Java/Spring Boot)
# ==============================
# 编译输出目录
target/
backend/target/

# Java 字节码
*.class

# 你代码里生成的临时运行目录 (image_293091.png 里看到的)
tempCode/
backend/tempCode/

# Maven 包装器 (可选，一般建议保留，如果你想忽略也可以解开)
# .mvn/
# mvnw
# mvnw.cmd

# ==============================
# 3. 前端 Frontend (Vue/Node)
# ==============================
# 巨大的依赖包文件夹 (绝对不能上传！)
node_modules/
frontend/node_modules/

# 打包生成的静态文件
dist/
frontend/dist/

# 本地环境变量
.env.local
.env.*.local

# npm/yarn 错误日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==============================
# 4. 其他保护
# ==============================
# 所有的私钥文件
*.key
*.pem

#文件
*前端.md
*后端.md
*项目介绍.md